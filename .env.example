# Copy this file to .env and fill in local values.
# Do not commit real secrets.

# ===== Runtime profile =====
# dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# ===== Database =====
# Leave blank in dev to use H2 from application-dev.yml.
# DB_URL=jdbc:postgresql://your-host:5432/postgres?sslmode=require
# DB_DRIVER=org.postgresql.Driver
# DB_USERNAME=postgres
# DB_PASSWORD=YOUR_DATABASE_PASSWORD
# HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# DDL_AUTO=validate
# SHOW_SQL=false

# ===== Security =====
# Production must use a random value with at least 32 bytes.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Restrict CORS in production, comma separated.
RENLINK_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Agora =====
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# ===== Xfyun RTASR LLM =====
XFYUN_RTASR_LLM_ENABLED=false
XFYUN_RTASR_LLM_APP_ID=
XFYUN_RTASR_LLM_ACCESS_KEY_ID=
XFYUN_RTASR_LLM_ACCESS_KEY_SECRET=
XFYUN_RTASR_LLM_BASE_URL=wss://office-api-ast-dx.iflyaisol.com/ast/communicate/v1
XFYUN_RTASR_LLM_AUDIO_ENCODE=pcm_s16le
XFYUN_RTASR_LLM_LANG=autodialect
XFYUN_RTASR_LLM_SAMPLERATE=16000
XFYUN_RTASR_LLM_ROLE_TYPE=0
XFYUN_RTASR_LLM_PD=com

# ===== Xfyun Online TTS =====
XFYUN_TTS_ENABLED=false
XFYUN_TTS_APP_ID=
XFYUN_TTS_API_KEY=
XFYUN_TTS_API_SECRET=
XFYUN_TTS_BASE_URL=wss://tts-api.xfyun.cn/v2/tts
XFYUN_TTS_VCN=x4_xiaoyan
XFYUN_TTS_AUE=lame
XFYUN_TTS_AUF=audio/L16;rate=16000
XFYUN_TTS_TTE=UTF8
XFYUN_TTS_SPEED=50
XFYUN_TTS_VOLUME=50
XFYUN_TTS_PITCH=50
XFYUN_TTS_SFL=1

# ===== Sign language avatar =====
# Never expose this value directly to frontend code.
SIGN_LANGUAGE_ENABLED=false
SIGN_LANGUAGE_APP_SECRET=
